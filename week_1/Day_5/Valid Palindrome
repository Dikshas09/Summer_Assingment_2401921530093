class Solution {
public:
    bool isPalindrome(string s) {
        string t="";
        for(int i=0;i<s.length();i++){
            if(isalnum(s[i])){
                t.push_back(tolower(s[i]));
            }
        }
        string rev = t;
        reverse(rev.begin(),rev.end());
        if(t!=rev){
            return false;
        }
        return true;
    }
};
