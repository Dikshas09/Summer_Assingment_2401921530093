class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        double sum=0;
        int n= nums.size();
        for(int i=0;i<k;i++){
            sum+=nums[i];
        }
        double msum=sum;
        for(int i=k;i<n;i++){
            sum= sum- nums[i-k]+ nums[i];
            msum = max(msum, sum);
        }
        return msum/k;
    }
};
