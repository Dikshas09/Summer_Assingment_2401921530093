class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int cost;
        int minm=prices[0];
        int pro=0;
        int n=prices.size();
        for(int i=1;i<n;i++){
            cost=prices[i]-minm;
            pro=max(pro,cost);
            minm=min(prices[i],minm);
        }
        return pro;
    }
};
