class solution{
public:
    bool isSubsequence(string s, string t) {
        int n1 = s.length();
        int m = t.length();
        if(n1==0) return true;
        if(n1>m) return false;
        int c=0;
        for(int i=0;i<m;i++){
            if(t[i]==s[c]){
                c++;
            }
            if(c == n1) return true;
        }
        return (c==n1);
    }
};
